  "builtin_embedding_dim": 384,
  "embedding_timeout": 120,
  "auto_pull_local_models": true,
  "semantic_retrieval_enabled": true,
  "semantic_retrieval_top_k": 8,
  "highlight_candidate_limit": 300,
  "highlight_output_limit": 50,
